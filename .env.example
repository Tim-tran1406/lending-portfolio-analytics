# Copy this file to ".env" and fill in real values.
# ".env" is gitignored, so your real settings are never committed.
#
#   cp .env.example .env
#
# These settings are read by the Python ingest scripts and by dbt.

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=lending
POSTGRES_USER=lending
POSTGRES_PASSWORD=change_me

# Schema where the raw, untouched data is loaded by Python.
POSTGRES_SCHEMA_RAW=raw
